{
  "name": "day-08-frontend-vite",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "web:install": "npm --prefix web install",
    "web:build": "npm --prefix web run build",
    "deploy": "npm run web:build && npx cdk deploy --require-approval never"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1124.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.255.0",
    "constructs": "^10.5.0"
  }
}
