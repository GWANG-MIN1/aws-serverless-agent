{
  "app": "npx ts-node --prefer-ts-exts bin/day-16-lambda-edge.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules",
      "test"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:useCdkManagedLogGroup": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"]
  }
}
